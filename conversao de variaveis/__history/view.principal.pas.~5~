unit view.principal;

interface

uses
  Winapi.Windows, Winapi.Messages, System.SysUtils, System.Variants, System.Classes, Vcl.Graphics,
  Vcl.Controls, Vcl.Forms, Vcl.Dialogs, Vcl.StdCtrls;

type
  TForm1 = class(TForm)
    edt1: TEdit;
    edt2: TEdit;
    Button1: TButton;
    edt3: TEdit;
    procedure FormCreate(Sender: TObject);

  private
    { Private declarations }
  public
    { Public declarations }
  end;

var
  Form1: TForm1;

implementation

{$R *.dfm}

procedure TForm1.FormCreate(Sender: TObject);

 var
  valor1, valor2, total: double;

begin

   valor1 := StrToFloat(edt1.Text);

   valor2 := StrToFloatDef(edt2.Text,0);

   total := valor1 + valor2;

   edt3.Text := FloatToStr(total);






end;

end.
