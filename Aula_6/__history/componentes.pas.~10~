implementation

{$R *.dfm}

procedure TfrmComponentes.btnExibirNomeClick(Sender: TObject);
begin
  ShowMessage(edtNome.Text);

  {
    o componente rgdEscolha se comporta como um array de radio buttons
    nisso quando eu faÁo o if testar se o ItemIndex È 0 eu estou testando
    se a primeira opÁ„o foi marcada porque
      [0] - sim
      [1] - n„o
  }

  if rgdEscolha.ItemIndex = 0 then

  begin
   

    {
     se o indicwe form igual a 0 a opÁ„op esclhida È sim ent„o ele vai adiocnar uma linha
     no memo
    }

    memLista.Lines.Add(edtNome.Text + ' ' + cboNome.Text);
  end;

end;

end.
