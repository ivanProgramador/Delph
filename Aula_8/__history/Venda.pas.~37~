unit Venda;

interface

uses
  Winapi.Windows, Winapi.Messages, System.SysUtils, System.Variants, System.Classes, Vcl.Graphics,
  Vcl.Controls, Vcl.Forms, Vcl.Dialogs, Data.DB, Vcl.Grids, Vcl.DBGrids,
  Vcl.StdCtrls, Vcl.ExtCtrls, Vcl.ComCtrls, Vcl.Samples.Spin, Vcl.NumberBox;

type
  TfrmVenda = class(TForm)
    pnlClientes: TPanel;
    Label1: TLabel;
    Label2: TLabel;
    edtFiltroCli: TEdit;
    gdrClientes: TDBGrid;
    pnlProdutos: TPanel;
    Label3: TLabel;
    edtFiltroProd: TEdit;
    Label4: TLabel;
    gdrProdutos: TDBGrid;
    pnlVenda: TPanel;
    Button1: TButton;
    Button2: TButton;
    Button3: TButton;
    lblCodVenda: TLabel;
    COD: TLabel;
    ListView1: TListView;
    Label5: TLabel;
    Label6: TLabel;
    spQtdProd: TSpinEdit;
    Label7: TLabel;
    lblNome: TLabel;
    edtNome: TEdit;
    edtNomeProd: TEdit;
    Label8: TLabel;
    Label9: TLabel;
    tnValorProduto: TNumberBox;
    Label10: TLabel;
    tnTotalProduto: TNumberBox;
    procedure edtFiltroCliChange(Sender: TObject);
    procedure edtFiltroProdChange(Sender: TObject);
    procedure gdrClientesCellClick(Column: TColumn);
    procedure gdrProdutosCellClick(Column: TColumn);
    procedure spQtdProdExit(Sender: TObject);
  private
    { Private declarations }
  public
    { Public declarations }
  end;

var
  frmVenda: TfrmVenda;

implementation

{$R *.dfm}

uses dmDados;

procedure TfrmVenda.edtFiltroCliChange(Sender: TObject);
begin
      // quando eu faço a chamada dessa "QryClientes"
      // o sistema faz auma busca na tabela e traz a lista toda
      // entăo quando eu digo "do" depois dessa chamada basiacamente estou dizendo faça com essa lista

      with dmDados.DataModule1.QryClientes do

        begin
         // o filtro de peqauisa deve iniciar limpo pra depois eu colocar alguma coisa nele

         Filtered := false;

         // testando se tem algum texto diferente de vazio no text da pesquisa

          if Trim(edtFiltroCli.Text) = '' then

          // se năo tiver nada ele define o filtro zavio e para de tentar consultar
          begin
            Filter := '';

            //sai do porcedimento
            Exit;
          end;


          //caso tenha texto ele vai buscar
          //a alinha abaixo faz uma like e troca o %S eplo vazlor da pesquisa
          // o format ajuda a formatar a string sql

          Filter := Format('NOME_CLI LIKE ''%%%s%%''', [edtFiltroCli.Text]);

          // agora eu ativo o filtro
          Filtered := True;

         // entăo com o resultado em măos eu ligo a resposta filtada e ela entra na tabela
         // atraves da query que ao inves de trazer todos os resultados ela traz so oque sobrou depois do filtro
         // eo conteudo dela vai mudando conforme o conteudo do campo

         Filtered := true;
     end;
end;

procedure TfrmVenda.edtFiltroProdChange(Sender: TObject);
begin
     with dmDados.DataModule1.QryProdutos do
     begin
        Filtered := false;

        if Trim(edtFiltroProd.Text) = '' then
          begin
            Filter := '';
            Exit;
          end;

        Filter := Format('NOME_PROD LIKE ''%%%s%%''',[edtFiltroProd.Text]);

        Filtered := true;
        Filtered := true;

     end;
end;

procedure TfrmVenda.gdrClientesCellClick(Column: TColumn);
begin

    //essa rpocedure é disparada quando o usuario seleciona uma celula
    // da tabela entăo eu pego o indice 1 do array fields e mando o valor delee pra o text
    // do edtNome pra funcionar tem que ativar o dgOnRowSelect

    edtNome.Text := gdrClientes.Fields[1].Value;
end;

procedure TfrmVenda.gdrProdutosCellClick(Column: TColumn);
begin
    edtNomeProd.Text := gdrProdutos.Fields[1].Value;
    tnValorProduto.Text := gdrProdutos.Fields[3].Value;

end;


//calculando o valor total depois que o usuario
//termina de definir a quantidade que ele vai querer

procedure TfrmVenda.spQtdProdExit(Sender: TObject);

var
  qtd: integer;
  total: Real;

begin

  //convertendo o valor que vem do spin pra inteiro
  qtd := StrToInt(spQtdProd.Text);

  //usando o valor convertido pra muliplicar pelo valor do produto
  //e jogar na variavel total

  total := qtd * tnValorProduto.Value;

  //colcando o valor do total dntro do texto do total produto
  tnTotalProduto.Text := FloatToStr(total);





end;

end.
