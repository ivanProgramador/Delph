unit uMain;

interface

uses
  Winapi.ShellAPI,
  Winapi.Windows,
  Winapi.Messages,
  System.SysUtils,
  System.Variants,
  System.Classes,
  Vcl.Graphics,
  Vcl.Controls,
  Vcl.Forms,
  Vcl.Dialogs,
  Vcl.Buttons,
  Vcl.StdCtrls,
  System.Generics.Collections, // Classe de listas
  uScripts;                     // Chamando a nova unit do Script

type
  TForm1 = class(TForm)
    edtCaminho: TEdit;
    cbTipo: TComboBox;
    lbScripts: TListBox;
    btnAdicionar: TButton;
    btnApagar: TButton;
    btnEditar: TButton;
    edtNome: TEdit;
    Label1: TLabel;
    Label2: TLabel;
    Label3: TLabel;
    btnExecutar: TButton;

    procedure FormCreate(Sender: TObject);
    procedure FormDestroy(Sender: TObject);
    procedure btnAdicionarClick(Sender: TObject);
    procedure btnApagarClick(Sender: TObject);
    procedure btnEditarClick(Sender: TObject);
    procedure btnExecutarClick(Sender: TObject);
  private
    { Private declarations }
    FPosicaoEdicao: integer;
    ListaDeScripts: TObjectList<TScript>; // Lista agora é de Scripts!
  public
    { Public declarations }
  end;

var
  Form1: TForm1;

implementation

{$R *.dfm}

  procedure AtualizarListaInterface;
    var
      Script: TScript;
    begin
      Form1.lbScripts.Items.Clear;

      for Script in Form1.ListaDeScripts do
      begin
        // Mostra o nome e o tipo do script na lista
        Form1.lbScripts.Items.Add(Script.Nome + ' [' + Script.Tipo + ']');
      end;
  end;

  procedure TForm1.FormCreate(Sender: TObject);
    begin
      ListaDeScripts := TObjectList<TScript>.Create(True);
    end;

    procedure TForm1.FormDestroy(Sender: TObject);
    begin
      ListaDeScripts.Free;
  end;

  procedure TForm1.btnAdicionarClick(Sender: TObject);
    var
      NovoScript: TScript;
    begin
      if (edtNome.Text = '') or (edtCaminho.Text = '') or (cbTipo.Text = '') then
      begin
        ShowMessage('Por favor, preencha todos os campos!');
        Exit;
      end;

      NovoScript := TScript.Create(edtNome.Text, edtCaminho.Text, cbTipo.Text);
      ListaDeScripts.Add(NovoScript);

      AtualizarListaInterface;

      edtNome.Clear;
      edtCaminho.Clear;
      cbTipo.ItemIndex := -1; // Limpa a seleçăo do ComboBox
      edtNome.SetFocus;
  end;

  procedure TForm1.btnApagarClick(Sender: TObject);
    var
      PosicaoSelecionada: integer;
    begin
      PosicaoSelecionada := lbScripts.ItemIndex;

      if PosicaoSelecionada = -1 then
      begin
        ShowMessage('Por favor, selecione um script na lista para apagar!');
        Exit;
      end;

      ListaDeScripts.Delete(PosicaoSelecionada);
      AtualizarListaInterface;
  end;

  procedure TForm1.btnEditarClick(Sender: TObject);
  var
    ScriptSelecionado: TScript;
  begin
    if btnEditar.Tag = 0 then
    begin
      FPosicaoEdicao := lbScripts.ItemIndex;

      if FPosicaoEdicao = -1 then
      begin
        ShowMessage('Selecione um script na lista para editar!');
        Exit;
      end;

    ScriptSelecionado := ListaDeScripts[FPosicaoEdicao];

    edtNome.Text    := ScriptSelecionado.Nome;
    edtCaminho.Text := ScriptSelecionado.Caminho;
    cbTipo.Text     := ScriptSelecionado.Tipo;

    btnEditar.Caption    := 'Salvar Alteraçăo';
    btnEditar.Tag        := 1;
    btnAdicionar.Enabled := False;
    edtNome.SetFocus;
  end
  else
      begin
        if (edtNome.Text = '') or (edtCaminho.Text = '') or (cbTipo.Text = '') then Exit;

        ListaDeScripts[FPosicaoEdicao].Nome    := edtNome.Text;
        ListaDeScripts[FPosicaoEdicao].Caminho := edtCaminho.Text;
        ListaDeScripts[FPosicaoEdicao].Tipo    := cbTipo.Text;

        AtualizarListaInterface;

        btnEditar.Caption    := 'Editar Selecionado';
        btnEditar.Tag        := 0;
        btnAdicionar.Enabled := True;
        edtNome.Clear;
        edtCaminho.Clear;
        cbTipo.ItemIndex := -1;
      end;
  end;

  procedure TForm1.btnExecutarClick(Sender: TObject);
    var
      PosicaoSelecionada: integer;
      ScriptSelecionado: TScript;
      Comando, Parametros: string;
    begin
      // 1. Verifica se o usuário selecionou algum script na lista
      PosicaoSelecionada := lbScripts.ItemIndex;

      if PosicaoSelecionada = -1 then
      begin
        ShowMessage('Por favor, selecione um script na lista para executar!');
        Exit;
      end;

      // 2. Pega o objeto do script que está na memória
      ScriptSelecionado := ListaDeScripts[PosicaoSelecionada];

      // 3. Regra de execuçăo baseada no Tipo do Script usando POO
      if ScriptSelecionado.Tipo = 'Batch' then
      begin
        // Para arquivos .bat, executamos o próprio arquivo diretamente
        Comando    := ScriptSelecionado.Caminho;
        Parametros := '';
      end
      else if ScriptSelecionado.Tipo = 'PowerShell' then
      begin
        // Para PowerShell, chamamos o executável do Windows passando o caminho como parâmetro
        Comando    := 'powershell.exe';
        Parametros := '-NoProfile -ExecutionPolicy Bypass -File "' + ScriptSelecionado.Caminho + '"';
      end;

      // 4. A mágica acontece aqui: Executa o comando no Windows
      ShellExecute(0, 'open', PChar(Comando), PChar(Parametros), nil, SW_SHOWNORMAL);
    end;



end.
