{$R *.dfm}

uses dmDados;

procedure TfrmVenda.edtFiltroCliChange(Sender: TObject);
begin
      // quando eu faÁo a chamada dessa "QryClientes"
      // o sistema faz auma busca na tabela e traz a lista toda
      // ent„o quando eu digo "do" depois dessa chamada basiacamente estou dizendo faÁa com essa lista

      with dmDados.DataModule1.QryClientes do
        begin
         // o filtro de peqauisa deve iniciar limpo pra depois eu colocar alguma coisa nele

         Filtered := false;

         //Aqui tem uma string sql implicita
         //eu estou fazendo um like com base no texto que vier dento do campo de filtro
         // a QuoteStr() recebe os parametros de Busca sendo 2 diretovas sql  "%" contacenetadas com o objeto de busca

         Filter := ' NOME_CLI like ' + QuotedStr('%' + edtFiltroCli.Text + '%');

         // ent„o com o resultado em m„os eu ligo a resposta filtada e ela entra na tabela
         // atraves da query que ao inves de trazer todos os resultados ela traz so oque sobrou depois do filtro
         // eo conteudo dela vai mudando conforme o conteudo do campo

         Filtered := true;
     end;
end;

end.
